<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App-level privacy manifest. REQUIRED by App Store review since
	     2024-05-01 — a missing or inaccurate manifest is an automatic
	     rejection before a human reviews the app.

	     IMPORTANT: after adding this file, in Xcode drag it into the Runner
	     target and confirm "Target Membership: Runner" is ticked so it ships
	     inside the app bundle. Then run Product > Generate Privacy Report to
	     validate it merges cleanly with the Flutter engine + plugin manifests. -->

	<!-- DokoDocs does not track users across apps/websites (no ad SDKs, no
	     analytics that link to third-party data). -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- Guest mode (the default path) collects nothing. If/when the user
	     signs in with Google/Apple, only auth identifiers are used and are
	     NOT linked to tracking. Add a NSPrivacyCollectedDataType entry here
	     (type NSPrivacyCollectedDataTypeUserID, linked=YES, tracking=NO,
	     purpose AppFunctionality) once sign-in is enabled in a shipped
	     build, and keep it consistent with the App Privacy form in App
	     Store Connect. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

	<!-- Required-reason APIs used by the app's own file handling. Each entry
	     must have a valid reason code or Apple rejects the build. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- File timestamps: DokoDocs shows saved-document dates and
			     writes scanned files it created. Reason C617.1 = access
			     timestamps of files inside the app's own container. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>C617.1</string>
			</array>
		</dict>
		<dict>
			<!-- Disk space: checked before saving a scan/PDF so the write
			     doesn't fail on a full device. E174.1 = write/delete files
			     to free space, checked from the app itself. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryDiskSpace</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>E174.1</string>
			</array>
		</dict>
		<dict>
			<!-- User defaults: used to persist app settings (language,
			     onboarding-seen). CA92.1 = access info only from the app
			     itself, not shared with other apps. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
